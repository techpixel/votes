# Prisma Postgres connection string
# Provision one at https://console.prisma.io (or run `npx prisma dev` locally)
DATABASE_URL=""

# Hack Club Auth OAuth app — register at https://auth.hackclub.com/developer/apps
# Redirect URI must be {APP_ORIGIN}/oauth/callback
HACKCLUB_CLIENT_ID=""
HACKCLUB_CLIENT_SECRET=""
APP_ORIGIN="http://localhost:5173"

# Airtable personal access token with data.records:read + data.records:write
# scoped to the event's base (Crux: app2wgVgZnozM92TT)
AIRTABLE_API_KEY=""

# Hack Club CDN API key (create one at https://cdn.hackclub.com) — screenshots
# are uploaded here so Airtable can fetch them as attachments
HACKCLUB_CDN_TOKEN=""

# Comma-separated emails that get admin access on sign-in
ADMIN_EMAILS=""
